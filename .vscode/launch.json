    "version": "0.2.0",
    "configurations": [
        {
            "name": "Bee Keeper (Safe Mode - F5 FIX)",
            "request": "launch",
            "type": "dart",
            "noDebug": true,
            "args": [
                "--web-renderer", "html",
                "--no-enable-impeller",
                "--release"
            ]
        },
        {
            "name": "Flutter: Attach to Device",
            "type": "dart",
            "request": "attach"
        },
        {
            "name": "uj_project",
            "request": "launch",
            "type": "dart",
            "noDebug": true,
            "args": [
                "--web-renderer", "html",
                "--no-enable-impeller"
            ]
        },
        {
            "name": "uj_project (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "uj_project (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}